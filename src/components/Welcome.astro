---
const photos = {
  heroCutout: '/a31f9b28-1ad2-42ad-8622-e222b47c7a3c-removebg-preview.png',
  portrait: '/batu-fotos/a31f9b28-1ad2-42ad-8622-e222b47c7a3c.jpg',
  heroKick: '/batu-fotos/7b2ff42e-e0b7-4412-ac62-aabfff971284.jpg',
  about: '/batu-fotos/2c85e53a-4ffb-4e07-9c7a-08d06abdbbbb-2.jpg',
  signature: '/batu-fotos/1df178bc-c441-4ac9-a796-c26406c8cbc1.jpg',
  sideProfile: '/batu-fotos/070a0bca-84ad-4075-8d8d-f9beb73cc771.jpg',
  strike: '/batu-fotos/9e0f51ba-f127-420f-b839-7937fa812a45.jpg',
  wide: '/batu-fotos/30e651df-907b-4e39-9d9e-590448e7f633.jpg',
  celebrateLine: '/batu-fotos/b20b4510-bece-42ea-b111-a6a37a3648e4-2.jpg',
  cupShot: '/batu-fotos/bf00c074-dadc-421f-b3d1-d62ddbf99934.jpg',
  stadium: '/batu-fotos/bd4e4722-6958-4e22-b82c-2c8965cc1c93-2.jpg',
  team: '/batu-fotos/39dfabb0-feac-4469-b3d6-c9f0fb751d5e.jpg',
  duel: '/batu-fotos/b3aba463-5cd1-4d1a-9604-ccff357fd6c1.jpg',
  action1: '/batu-fotos/f0c0c344-12a6-4e01-9d36-0080a111ec9c-2.jpg',
  action2: '/batu-fotos/d71596f1-87c4-4296-b532-6b0092b4a8d6-2.jpg',
  action3: '/batu-fotos/4be4d069-7a85-412b-827e-60c83ca494a7-2.jpg',
  action4: '/batu-fotos/75a9e1d3-15bc-4172-a7cb-565164ec543b-2.jpg',
  action5: '/batu-fotos/f94e9806-2543-4c77-9b06-79feab85871f-2.jpg',
  action6: '/batu-fotos/86b4d0f9-76c5-4154-8f54-84afa709a0fd.jpg',
  celebrate2: '/batu-fotos/256e95b3-ddf0-4755-842f-e6b1aabc085e-2.jpg',
  celebrate3: '/batu-fotos/590f2100-8ebe-4676-a655-f70f7aef7b5a-2.jpg',
  mates: '/batu-fotos/5261dc5d-1995-4311-aaf3-aa32a36dfcd5.jpg',
};
---

<main>
  <nav class="nav">
    <a href="#top" class="nav__logo">BI<span>·</span>10</a>
    <ul>
      <li><a href="#player">Oyuncu</a></li>
      <li><a href="#trophy">Antalya Kupası</a></li>
      <li><a href="#gallery">Fotoğraflar</a></li>
      <li><a href="#contact">İletişim</a></li>
    </ul>
  </nav>

  <section id="top" class="hero">
    <div class="hero__grid">
      <div class="hero__text">
        <h1 class="hero__name">
          <span class="hero__line"><span>Batu</span></span>
          <span class="hero__line"><span class="italic">Ilgaç.</span></span>
        </h1>
        <p class="hero__club" data-reveal data-reveal-delay="500">Beşiktaş JK · U12 Akademi · 2026</p>
      </div>
      <div class="hero__cutout">
        <img src={photos.heroCutout} alt="Batu sahada" />
      </div>
    </div>
  </section>

  <!-- OYUNCU — identity statement, Batu'nun kendi sözleri -->
  <section id="player" class="player">
    <p class="eyebrow" data-reveal>Oyuncu · Kendi sözleriyle</p>

    <blockquote class="manifesto" data-reveal data-reveal-delay="100">
      <p>
        "Top kaybedince<br/>
        <span class="manifesto__hit">geri kazanırım.</span>"
      </p>
      <cite>— Batu</cite>
    </blockquote>

    <ul class="traits" data-reveal data-reveal-stagger data-reveal-delay="250">
      <li><span>Orta saha.</span> İki yönlü.</li>
      <li>Çift ayak kullanır.</li>
      <li>Sabit forma numarası yok.</li>
    </ul>

    <p class="source" data-reveal data-reveal-delay="400">Kaynak: Batu'nun kendi cevapları.</p>
  </section>

  <!-- KUPA — tournament dominance story -->
  <section id="trophy" class="trophy">
    <header class="trophy__head">
      <p class="eyebrow" data-reveal>Takım Başarısı · Beşiktaş U12 · Antalya, 2025</p>
      <h2 data-reveal data-reveal-delay="80">Futbolun Gelecek<br/>Yıldızları Kupası</h2>
      <p class="trophy__status" data-reveal data-reveal-delay="160"><span class="trophy__status-mark">—</span> Namağlup <span class="italic">Şampiyon.</span></p>
    </header>

    <!-- Headline stats: the story at a glance -->
    <div class="trophy__stats" data-reveal data-reveal-stagger>
      <div><strong>7</strong><span>Maç</span></div>
      <div><strong>14</strong><span>Atılan gol</span></div>
      <div><strong>2</strong><span>Yenilen gol</span></div>
      <div><strong>0</strong><span>Mağlubiyet</span></div>
    </div>

    <!-- The road to the final -->
    <div class="results">
      <div class="results__stage">
        <h3 class="results__label">Grup Maçları</h3>
        <ul class="results__list">
          <li><span class="t">Beşiktaş</span><em>5 – 0</em><span class="t t--opp">Gentilly FC</span></li>
          <li><span class="t">Beşiktaş</span><em>4 – 1</em><span class="t t--opp">Kemer Belediyespor</span></li>
          <li><span class="t">Beşiktaş</span><em>3 – 0</em><span class="t t--opp">Maltepe Elitspor</span></li>
          <li class="fav">
            <span class="t">Beşiktaş</span><em>0 – 0</em><span class="t t--opp">Olympique Lyon</span>
            <span class="fav-note">Batu'nun en sevdiği maç.</span>
          </li>
        </ul>
      </div>

      <div class="results__stage">
        <h3 class="results__label">Çeyrek Final</h3>
        <ul class="results__list">
          <li><span class="t">Beşiktaş</span><em>1 – 1 <small>· Pen. 5–4</small></em><span class="t t--opp">Antalyaspor</span></li>
        </ul>
      </div>

      <div class="results__stage">
        <h3 class="results__label">Yarı Final</h3>
        <ul class="results__list">
          <li><span class="t">Beşiktaş</span><em>0 – 0 <small>· Pen. 7–6</small></em><span class="t t--opp">Academy Bouchentouf</span></li>
        </ul>
      </div>

      <!-- The final gets its own weight -->
      <div class="results__stage results__stage--final">
        <h3 class="results__label results__label--final">Final</h3>
        <div class="final-card" data-reveal>
          <div class="final-card__line">
            <span class="final-card__team">Beşiktaş</span>
            <span class="final-card__score">1 – 0</span>
            <span class="final-card__opp">Villejuif Football</span>
          </div>
          <p class="final-card__verdict"><span class="italic">Şampiyon.</span></p>
        </div>
      </div>
    </div>

    <div class="awards">
      <p class="eyebrow">Turnuva Ödülleri</p>
      <ul>
        <li><em>Doğan Bülbül</em> &amp; <em>Ensar Eser Çakmakçı</em> — turnuvanın en iyi kalecileri.</li>
        <li><em>Onur Özgür Altun</em> — turnuvanın en iyi oyuncusu.</li>
      </ul>
    </div>

    <p class="source">Kaynak: Beşiktaş JK U12 Akademi paylaşımı.</p>
  </section>

  <!-- ALINTI — Annesinden -->
  <section class="showcase">
    <img class="showcase__bg" src={photos.stadium} alt="Maç anı, Antalya Kupası 2025" />
    <div class="showcase__quote">
      <p class="showcase__mark" data-reveal>"</p>
      <p class="showcase__body" data-reveal data-reveal-delay="120">
        Batu sahada azimli, konsantre ve tamamen adanmış oynuyor. Oyununa olan ciddiyeti her an hissediliyor.
      </p>
      <div class="showcase__attrib" data-reveal data-reveal-delay="280">
        <span class="showcase__attrib-role">Yazan</span>
        <span class="showcase__attrib-name">Annesi.</span>
      </div>
    </div>
  </section>

  <section id="gallery" class="gallery">
    <div class="gallery__head">
      <p class="eyebrow" data-reveal>Anlar · 2025</p>
      <h2 data-reveal data-reveal-delay="80">Kenar <span class="italic">çizgisinden.</span></h2>
      <p class="gallery__lede" data-reveal data-reveal-delay="160">Sezonun kaydedilen anları — maçlar, kutlamalar, aradaki sessizlikler.</p>
    </div>
    <div class="gallery__grid">
      <figure class="g g--hero" data-reveal><img src={photos.wide} alt="Akşam topu koruma" loading="lazy"/><figcaption>Akşam · Topu koruma</figcaption></figure>
      <figure class="g" data-reveal><img src={photos.cupShot} alt="Antalya Kupası pankartı önünde şut" loading="lazy"/><figcaption>Antalya Kupası</figcaption></figure>
      <figure class="g" data-reveal><img src={photos.portrait} alt="Sahada portre" loading="lazy"/><figcaption>Isınma</figcaption></figure>
      <figure class="g" data-reveal><img src={photos.duel} alt="Birebir mücadele" loading="lazy"/><figcaption>Birebir</figcaption></figure>
      <figure class="g" data-reveal><img src={photos.action5} alt="Kaleye şut" loading="lazy"/><figcaption>Şut</figcaption></figure>
      <figure class="g g--wide" data-reveal><img src={photos.celebrateLine} alt="Takım kutlaması" loading="lazy"/><figcaption>Düdükten sonra</figcaption></figure>
      <figure class="g" data-reveal><img src={photos.mates} alt="Takım arkadaşları" loading="lazy"/><figcaption>Kartal Yuvası</figcaption></figure>
      <figure class="g" data-reveal><img src={photos.action6} alt="Orta saha mücadelesi" loading="lazy"/><figcaption>Mücadele</figcaption></figure>
    </div>
  </section>

  <section class="team">
    <img src={photos.team} alt="Beşiktaş U12 takım fotoğrafı" />
    <div class="team__overlay">
      <p class="eyebrow light" data-reveal>Takım · 2025</p>
      <h2 class="team__statement" data-reveal data-reveal-delay="120">
        Bu sadece<br/>
        <span class="italic">bir başlangıç.</span>
      </h2>
      <p class="team__meta" data-reveal data-reveal-delay="280">Beşiktaş JK U12 Akademi · Antalya Kupası şampiyonu.</p>
    </div>
  </section>

  <footer id="contact" class="foot">
    <div class="foot__top">
      <p class="eyebrow">İletişim</p>
      <h2>İletişim Beşiktaş JK Akademi üzerinden.</h2>
      <p class="foot__lede">
        Bu sayfa resmi bir scouting profili değildir — aile tarafından hazırlanmış, 2025 sezonundan bir fotoğraf derlemesidir.
      </p>
    </div>
    <div class="foot__bottom">
      <span>© {new Date().getFullYear()} Batu Ilgaç</span>
      <span>Hazırlayan: <a href="https://github.com/smartlizardpy" target="_blank" rel="noreferrer">Ozan · @smartlizardpy</a></span>
    </div>
  </footer>
</main>

<style>
  main { overflow-x: hidden; }

  /* ========= subtle motion system ========= */
  [data-reveal] {
    opacity: 0; transform: translateY(18px);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0ms);
    will-change: opacity, transform;
  }
  [data-reveal].is-visible { opacity: 1; transform: translateY(0); }

  /* staggered children reveal */
  [data-reveal-stagger] > * {
    opacity: 0; transform: translateY(14px);
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  [data-reveal-stagger].is-visible > * {
    opacity: 1; transform: translateY(0);
  }
  [data-reveal-stagger].is-visible > *:nth-child(1) { transition-delay: 0ms; }
  [data-reveal-stagger].is-visible > *:nth-child(2) { transition-delay: 90ms; }
  [data-reveal-stagger].is-visible > *:nth-child(3) { transition-delay: 180ms; }
  [data-reveal-stagger].is-visible > *:nth-child(4) { transition-delay: 270ms; }

  /* hero name — per-line mask reveal on load */
  .hero__name { display: flex; flex-direction: column; }
  .hero__line {
    display: block; overflow: hidden;
  }
  .hero__line > span {
    display: inline-block;
    transform: translateY(105%);
    animation: heroLineRise 1.1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .hero__line:nth-child(2) > span { animation-delay: 120ms; }
  @keyframes heroLineRise {
    to { transform: translateY(0); }
  }

  /* hero cutout — gentle float + fade in */
  .hero__cutout img {
    opacity: 0;
    animation: cutoutIn 1.4s cubic-bezier(0.22, 1, 0.36, 1) 200ms forwards,
               cutoutFloat 7s ease-in-out 1.6s infinite;
  }
  @keyframes cutoutIn {
    from { opacity: 0; transform: translateY(14px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }
  @keyframes cutoutFloat {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-6px); }
  }
  .hero__cutout::before { animation: glowPulse 6s ease-in-out infinite; }
  @keyframes glowPulse {
    0%, 100% { opacity: 0.18; }
    50%      { opacity: 0.28; }
  }

  /* nav link underline on hover */
  .nav ul a {
    background-image: linear-gradient(var(--bjk-red), var(--bjk-red));
    background-size: 0 1px; background-repeat: no-repeat;
    background-position: 0 100%;
    transition: background-size 0.35s ease, color 0.25s ease;
  }
  .nav ul a:hover { background-size: 100% 1px; }

  /* tighter gallery hover */
  .g img { transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1), filter 0.9s ease; }

  /* final card subtle rise-in when revealed */
  .final-card[data-reveal] { transform: translateY(26px); }
  .final-card[data-reveal].is-visible { transform: translateY(0); }

  /* respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    [data-reveal], [data-reveal-stagger] > *,
    .hero__line > span, .hero__cutout img, .hero__cutout::before {
      opacity: 1 !important; transform: none !important;
      animation: none !important; transition: none !important;
    }
  }

  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1.25rem;
    font-weight: 600;
  }
  .eyebrow.light { color: rgba(255,255,255,0.8); }

  h1, h2, h3 { font-family: 'Instrument Serif', serif; font-weight: 400; letter-spacing: -0.02em; margin: 0; }
  .italic { font-style: italic; color: var(--bjk-red); }

  .nav {
    position: sticky; top: 0; z-index: 50;
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.25rem 2rem;
    background: rgba(245, 243, 238, 0.78);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }
  .nav__logo { font-family: 'Instrument Serif', serif; font-size: 1.5rem; letter-spacing: -0.02em; }
  .nav__logo span { color: var(--bjk-red); padding: 0 0.25rem; }
  .nav ul { display: flex; gap: 2rem; list-style: none; margin: 0; padding: 0; font-size: 0.95rem; font-weight: 500; }
  .nav ul a { position: relative; padding: 0.25rem 0; }
  .nav ul a:hover { color: var(--bjk-red); }

  .hero { padding: 4rem 2rem 0; min-height: 88vh; display: flex; flex-direction: column; justify-content: space-between; }
  .hero__grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 2rem; align-items: center; flex: 1; }
  .hero__text h1 { font-size: clamp(4rem, 14vw, 13rem); line-height: 0.88; letter-spacing: -0.04em; }
  .hero__club {
    margin: 2rem 0 0; padding: 1rem 0 0;
    border-top: 1px solid var(--line);
    font-size: 0.82rem; font-weight: 600;
    letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--ink); max-width: fit-content;
  }
  .hero__text .lede {
    max-width: 36ch; margin-top: 2rem;
    font-family: 'Instrument Serif', serif;
    font-size: clamp(1.25rem, 2vw, 1.6rem);
    color: #2a2a2a; line-height: 1.4; font-style: italic;
  }

  .hero__cutout { position: relative; height: 80vh; }
  .hero__cutout::before {
    content: ''; position: absolute; left: 50%; top: 50%;
    width: 60%; aspect-ratio: 1; transform: translate(-50%, -50%);
    background: radial-gradient(circle, var(--bjk-red) 0%, transparent 65%);
    opacity: 0.18; filter: blur(40px); z-index: 0;
  }
  .hero__cutout img {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: contain; object-position: bottom center;
    filter: drop-shadow(0 30px 40px rgba(0,0,0,0.18));
    z-index: 1;
  }


  /* ========= OYUNCU — identity statement ========= */
  .player { padding: 7rem 2rem 5rem; max-width: 1100px; margin: 0 auto; text-align: center; }
  .player .eyebrow { margin-bottom: 3rem; }

  .manifesto { margin: 0 0 3.5rem; padding: 0; }
  .manifesto p {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(3rem, 8vw, 7rem);
    line-height: 0.95; letter-spacing: -0.03em;
    margin: 0 0 1.25rem; color: var(--ink);
  }
  .manifesto__hit {
    display: inline-block; font-style: italic; color: var(--bjk-red);
    position: relative;
  }
  .manifesto__hit::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: 0.12em;
    height: 0.18em; background: var(--bjk-red); opacity: 0.12;
    border-radius: 2px;
  }
  .manifesto cite {
    font-style: normal; font-size: 0.82rem; letter-spacing: 0.22em;
    text-transform: uppercase; color: var(--muted); font-weight: 600;
  }

  .traits {
    list-style: none; padding: 0; margin: 0 auto;
    display: inline-flex; flex-wrap: wrap; gap: 0.75rem 1.5rem;
    justify-content: center; max-width: 48rem;
  }
  .traits li {
    font-family: 'Instrument Serif', serif; font-size: 1.4rem;
    color: #2a2a2a; line-height: 1.3;
  }
  .traits li span {
    color: var(--ink); font-weight: 500;
  }
  .traits li + li::before {
    content: '·'; color: var(--muted); margin-right: 1.5rem;
    font-family: 'Inter', sans-serif;
  }

  /* ========= TROPHY — tournament dominance story ========= */
  .trophy {
    padding: 6rem 2rem 7rem; max-width: 1100px; margin: 0 auto;
    border-top: 1px solid var(--line);
  }
  .trophy__head { max-width: 900px; margin-bottom: 3.5rem; }
  .trophy__head h2 {
    font-size: clamp(2.75rem, 6vw, 5rem);
    line-height: 0.98; letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .trophy__status {
    font-family: 'Instrument Serif', serif;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.1; margin: 0; color: var(--ink);
  }
  .trophy__status-mark { color: var(--bjk-red); font-weight: 500; margin-right: 0.3rem; }

  /* Headline stats — tighter, editorial */
  .trophy__stats {
    display: flex; flex-wrap: wrap; gap: 2.5rem 3.5rem;
    margin: 0 0 4rem; padding: 1.75rem 0;
    border-top: 1px solid var(--ink); border-bottom: 1px solid var(--line);
  }
  .trophy__stats > div {
    display: flex; flex-direction: column; gap: 0.15rem;
  }
  .trophy__stats strong {
    font-family: 'Instrument Serif', serif; font-weight: 400;
    font-size: clamp(2.25rem, 4vw, 3.5rem); line-height: 1; letter-spacing: -0.02em;
    color: var(--ink);
  }
  .trophy__stats > div:nth-child(4) strong { color: var(--bjk-red); }
  .trophy__stats span {
    font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--muted); font-weight: 600; margin-top: 0.15rem;
  }

  /* Results — stages, not a table */
  .results { margin: 0 0 3rem; }
  .results__stage + .results__stage { margin-top: 2rem; }
  .results__label {
    font-family: 'Inter', sans-serif; font-weight: 600;
    font-size: 0.72rem; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--muted); margin: 0 0 0.75rem;
  }
  .results__label--final {
    color: var(--bjk-red); font-size: 0.8rem; letter-spacing: 0.28em;
  }
  .results__list { list-style: none; padding: 0; margin: 0; }
  .results__list li {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 1.25rem;
    padding: 0.75rem 0; border-bottom: 1px solid var(--line);
    align-items: baseline; position: relative;
  }
  .results__list li:last-child { border-bottom: none; }
  .results__list .t { font-size: 1.05rem; }
  .results__list .t--opp { color: var(--muted); text-align: right; }
  .results__list em {
    font-style: normal; font-family: 'Instrument Serif', serif;
    font-size: 1.65rem; font-weight: 400; white-space: nowrap;
    min-width: 6rem; text-align: center; color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .results__list em small {
    font-family: 'Inter', sans-serif; font-weight: 500;
    color: var(--muted); margin-left: 0.25rem; font-size: 0.72rem;
    letter-spacing: 0.05em;
  }

  /* Favorite match row — a storyline, not a badge */
  .results__list li.fav { padding-bottom: 1.25rem; }
  .results__list li.fav .t--opp { color: var(--ink); }
  .fav-note {
    grid-column: 1 / -1;
    font-family: 'Instrument Serif', serif; font-style: italic;
    font-size: 1.05rem; color: var(--bjk-red);
    margin-top: 0.35rem;
  }

  /* Final card — the emotional peak */
  .results__stage--final { margin-top: 3rem; }
  .final-card {
    background: var(--ink); color: var(--paper);
    padding: 2.5rem 2rem; border-radius: 4px;
    position: relative; overflow: hidden;
  }
